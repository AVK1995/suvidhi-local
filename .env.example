# =====================================================================
# Suvidhi — Frontend Environment Variables
# Copy this file to `.env` (or `.env.local`) and fill in real values.
# Vite only exposes variables prefixed with VITE_ to the client bundle.
# =====================================================================

# ---------- Brand / Offer ----------
VITE_BRAND_NAME=Suvidhi
VITE_BRAND_EMAIL=innohealthbysush@gmail.com
VITE_BRAND_PHONE=+919810880970
VITE_BRAND_PHONE_DISPLAY=+91 98108 80970

# Pricing — Postpartum Restore launch ₹497 (full value ₹21,000).
VITE_OFFER_PRICE_INR=497
VITE_OFFER_FULL_PRICE_INR=21000
VITE_OFFER_CURRENCY=INR
VITE_OFFER_NAME=The Postpartum Restore

# ---------- Coupon ----------
# 100%-discount test coupon. Skips payment entirely and routes
# to /book-a-call so you can validate the redirect.
VITE_TEST_COUPON_CODE=tgotest2025
VITE_TEST_COUPON_DISCOUNT_PCT=100

# ---------- Razorpay (test keys) ----------
# Get from https://dashboard.razorpay.com/app/keys
VITE_RAZORPAY_KEY_ID=rzp_test_REPLACE_ME
VITE_RAZORPAY_COMPANY_NAME=InnoHealth · Suvidhi
VITE_RAZORPAY_THEME_COLOR=#CB4A5D

# ---------- Calendly ----------
# Full event URL — e.g. https://calendly.com/innohealthbysush/clarity-call
VITE_CALENDLY_URL=https://calendly.com/REPLACE_ME/clarity-call
VITE_CALENDLY_HIDE_GDPR=1
VITE_CALENDLY_HIDE_EVENT_TYPE_DETAILS=0

# ---------- Meta / Facebook Pixel + CAPI ----------
VITE_META_PIXEL_ID=REPLACE_ME
# CAPI is server-side; this is the proxy endpoint (e.g. on Cloudflare / Vercel
# Edge) that forwards the event to Meta with your CAPI access token securely.
VITE_META_CAPI_ENDPOINT=
VITE_META_TEST_EVENT_CODE=

# ---------- Pabbly Connect (webhook) ----------
# Webhook URL — every lead and order event POSTs to this address.
VITE_PABBLY_WEBHOOK_URL=

# ---------- WhatsApp Community ----------
VITE_WHATSAPP_COMMUNITY_URL=https://chat.whatsapp.com/REPLACE_ME

# ---------- Optional analytics ----------
VITE_GA4_MEASUREMENT_ID=
