# =====================================================================
# Suvidhi — Environment Variables (Next.js)
# Copy this file to `.env` (or `.env.local`) and fill in real values.
# Next.js only exposes variables prefixed with NEXT_PUBLIC_ to the browser
# bundle. Variables WITHOUT that prefix (e.g. RAZORPAY_KEY_SECRET) stay
# server-only and are never shipped to the client.
# =====================================================================

# ---------- Brand / Offer ----------
NEXT_PUBLIC_BRAND_NAME=Suvidhi
NEXT_PUBLIC_BRAND_EMAIL=innohealthbysush@gmail.com
NEXT_PUBLIC_BRAND_PHONE=+919810880970
NEXT_PUBLIC_BRAND_PHONE_DISPLAY=+91 98108 80970

# Pricing — Postpartum Restore launch ₹497 (full value ₹21,000).
# These two drive every price shown across the whole site (hero, launch
# offer, value stack, sticky bar, footer, checkout). Edit here, nowhere else.
NEXT_PUBLIC_OFFER_PRICE_INR=497
NEXT_PUBLIC_OFFER_FULL_PRICE_INR=21000
NEXT_PUBLIC_OFFER_CURRENCY=INR
NEXT_PUBLIC_OFFER_NAME=The Postpartum Restore

# ---------- Value-stack line items (INR) ----------
# The itemised "Recap of Everything You Will Get" prices. Their sum should
# match NEXT_PUBLIC_OFFER_FULL_PRICE_INR (5000+1500×4+2500+3000+4500 = 21,000).
NEXT_PUBLIC_VALUE_ASSESSMENT=5000
NEXT_PUBLIC_VALUE_DEPLETION_AUDIT=1500
NEXT_PUBLIC_VALUE_METABOLIC_AUDIT=1500
NEXT_PUBLIC_VALUE_SUPPLEMENT_AUDIT=1500
NEXT_PUBLIC_VALUE_NEURO_AUDIT=1500
NEXT_PUBLIC_VALUE_CALL=2500
NEXT_PUBLIC_VALUE_COMMUNITY=3000
NEXT_PUBLIC_VALUE_COACHING=4500

# ---------- Coupon ----------
# 100%-discount test coupon. Skips payment entirely and routes
# to /book-a-call so you can validate the redirect.
NEXT_PUBLIC_TEST_COUPON_CODE=tgotest2025
NEXT_PUBLIC_TEST_COUPON_DISCOUNT_PCT=100

# ---------- Razorpay ----------
# Public key id (safe to ship to the browser).
# Get from https://dashboard.razorpay.com/app/keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_REPLACE_ME
NEXT_PUBLIC_RAZORPAY_COMPANY_NAME=InnoHealth · Suvidhi
NEXT_PUBLIC_RAZORPAY_THEME_COLOR=#CB4A5D
# SERVER-ONLY secret — used by app/api/razorpay/* route handlers to create
# orders and verify signatures. Never prefix this with NEXT_PUBLIC_.
RAZORPAY_KEY_SECRET=REPLACE_ME

# ---------- Calendly ----------
# Full event URL — e.g. https://calendly.com/innohealthbysush/clarity-call
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/REPLACE_ME/clarity-call
NEXT_PUBLIC_CALENDLY_HIDE_GDPR=1
NEXT_PUBLIC_CALENDLY_HIDE_EVENT_TYPE_DETAILS=0

# ---------- Meta / Facebook Pixel + CAPI ----------
NEXT_PUBLIC_META_PIXEL_ID=REPLACE_ME
# CAPI is server-side; this is the proxy endpoint (e.g. on Cloudflare / Vercel
# Edge) that forwards the event to Meta with your CAPI access token securely.
NEXT_PUBLIC_META_CAPI_ENDPOINT=
NEXT_PUBLIC_META_TEST_EVENT_CODE=

# ---------- Pabbly Connect (webhook) ----------
# Webhook URL — every lead and order event POSTs to this address.
NEXT_PUBLIC_PABBLY_WEBHOOK_URL=

# ---------- WhatsApp Community ----------
NEXT_PUBLIC_WHATSAPP_COMMUNITY_URL=https://chat.whatsapp.com/REPLACE_ME

# ---------- Optional analytics ----------
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
